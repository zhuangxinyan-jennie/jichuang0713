# DashScope / Bailian CosyVoice (cloud)

# Required
# DASHSCOPE_API_KEY=sk-xxxxxxxx

# Optional: after enroll_xiongda_dashscope.py, voice_id is cached under outputs/
# DASHSCOPE_VOICE_ID=cosyvoice-v3-flash-xiongda-xxxxxx

# Model must match the one used during voice enrollment
DASHSCOPE_COSYVOICE_MODEL=cosyvoice-v3-flash

# Optional workspace-specific endpoint
# DASHSCOPE_WORKSPACE_ID=your-workspace-id
# DASHSCOPE_REGION=cn-beijing
# DASHSCOPE_API_BASE=https://dashscope.aliyuncs.com/api/v1

# Board speaker
BOARD_SPEAKER_URL=http://192.168.137.100:9891/play

# Force cloud backend when starting tts_server.py
XIONGDA_TTS_BACKEND=dashscope
XIONGDA_TTS_DEVICE=cloud
XIONGDA_TTS_PORT=9890
