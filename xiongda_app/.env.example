# 熊大 GPT-SoVITS 语音服务（gpt_xiongda_portable 里运行 tts_server.py）
VITE_XIONGDA_TTS_URL=http://127.0.0.1:9888

# 设为 true 时只用浏览器朗读，不请求上面的服务
# VITE_XIONGDA_TTS_DISABLED=true

# 剧情语音默认：优先 public/theater_voice/tp_*.wav，缺失则请求 SoVITS（熊大声线）。
# 若纯语音触发时浏览器拦截播放导致静音，可临时设为 1 改用系统朗读（非克隆音色）。
# VITE_STORY_AUDIO_FALLBACK_BROWSER=1

# 设为 true 时在「游客感知」卡片等处显示 API、端口、board_bridge 等调试说明（默认关闭，适合面向游客演示）
# VITE_AGENT_PIPELINE_DEBUG_UI=true

# 演示环境显示“演示人流预警”按钮；正式部署设为 0。
# 后端需同时设置 SAFETY_DEMO_ENABLED=1。
VITE_SAFETY_DEMO_ENABLED=1
